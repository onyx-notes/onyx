<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ backup/transfer rules. Correctness, not preference:

     * device.key is the Ed25519 seed whose hash is this device's CRDT
       peer id. If an OS backup restored it to a second device, two peers
       would share an id and corrupt the CRDT history. It must never
       leave this device.
     * vaults/ holds note data plus derived state (.onyx index, tantivy,
       sync cursor). A restored stale sync cursor double-applies ops, and
       the notes themselves are recovered losslessly through sync (or the
       user's own encrypted backups) — that is the product's restore
       story. A restored app starts clean and re-syncs.
     * The onyx.secrets prefs hold AndroidKeyStore-encrypted blobs that
       are undecryptable on any other device; restoring them is noise.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="device.key" />
        <exclude domain="root" path="vaults" />
        <exclude domain="sharedpref" path="onyx.secrets.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="device.key" />
        <exclude domain="root" path="vaults" />
        <exclude domain="sharedpref" path="onyx.secrets.xml" />
    </device-transfer>
</data-extraction-rules>
