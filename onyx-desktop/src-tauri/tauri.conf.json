{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onyx",
  "version": "0.1.0",
  "identifier": "dev.onyx.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Onyx",
        "width": 1280,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' onyx: data:; connect-src 'self' onyx: ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false
  }
}
