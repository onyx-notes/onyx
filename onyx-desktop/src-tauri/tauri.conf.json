{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onyx",
  "version": "0.1.0",
  "identifier": "dev.onyx.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Onyx",
        "width": 1280,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' onyx: data:; connect-src 'self' onyx: ipc: http://ipc.localhost; frame-src onyx: http://onyx.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Fast, private, self-hosted notes",
    "longDescription": "Onyx is an open-source, self-hosted markdown knowledge base with end-to-end encrypted sync \u2014 a faster, privacy-first alternative to Obsidian that opens your existing vault in place.",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["onyx"]
      }
    },
    "updater": {
      "active": false,
      "endpoints": [
        "https://releases.onyx.example/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": ""
    }
  }
}